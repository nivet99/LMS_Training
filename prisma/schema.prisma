generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  ADMIN
  INSTRUCTOR
  LEARNER
}

enum CourseStatus {
  DRAFT
  IN_REVIEW
  PUBLISHED
  ARCHIVED
}

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  ALL_LEVELS
}

enum LessonType {
  VIDEO
  PDF
  TEXT
  QUIZ
  SCORM
  EMBED
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum DiscountType {
  PERCENTAGE
  FIXED
  FREE
}

enum XPReason {
  LESSON_COMPLETE
  QUIZ_PASS
  FORUM_POST
  DAILY_LOGIN
  STREAK_7
  STREAK_30
  STREAK_100
  COURSE_COMPLETE
}

enum QuestionType {
  MULTIPLE_CHOICE
  TRUE_FALSE
  FILL_BLANK
  MATCHING
  SHORT_ANSWER
}

// ─── Auth (Auth.js v5) ───────────────────────────────────────────────────────

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String    @unique
  emailVerified  DateTime?
  hashedPassword String?
  image          String?
  role           Role      @default(LEARNER)
  locale         String    @default("th")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  accounts     Account[]
  sessions     Session[]
  courses      Course[]         @relation("InstructorCourses")
  enrollments  Enrollment[]
  progress     LessonProgress[]
  certificates Certificate[]
  userBadges   UserBadge[]
  xpLedger     XPTransaction[]
  payments     Payment[]
  subscription Subscription?
  forumPosts   ForumPost[]
  reviews      Review[]
  liveClasses  LiveClass[]      @relation("InstructorLiveClasses")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Course Models ───────────────────────────────────────────────────────────

model Category {
  id      String   @id @default(cuid())
  name    String
  slug    String   @unique
  icon    String?
  courses Course[]
}

model Course {
  id           String       @id @default(cuid())
  title        String
  slug         String       @unique
  description  String       @db.Text
  instructorId String
  categoryId   String?
  price        Decimal?     @db.Decimal(10, 2)
  currency     String       @default("THB")
  status       CourseStatus @default(DRAFT)
  language     String       @default("th")
  level        CourseLevel  @default(ALL_LEVELS)
  thumbnail    String?
  publishAt    DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  instructor   User          @relation("InstructorCourses", fields: [instructorId], references: [id])
  category     Category?     @relation(fields: [categoryId], references: [id])
  chapters     Chapter[]
  lessons      Lesson[]
  enrollments  Enrollment[]
  certificates Certificate[]
  liveClasses  LiveClass[]
  reviews      Review[]
  payments     Payment[]
}

model Chapter {
  id       String   @id @default(cuid())
  courseId String
  title    String
  order    Int

  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]
}

model Lesson {
  id            String     @id @default(cuid())
  chapterId     String
  courseId      String
  title         String
  type          LessonType
  order         Int
  duration      Int?
  isFree        Boolean    @default(false)
  muxAssetId    String?
  muxPlaybackId String?
  youtubeUrl    String?
  s3Key         String?
  content       String?    @db.Text
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  chapter  Chapter          @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  course   Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  progress LessonProgress[]
  quiz     Quiz?
}

// ─── Progress & Enrollment ───────────────────────────────────────────────────

model Enrollment {
  userId      String
  courseId    String
  enrolledAt  DateTime  @default(now())
  completedAt DateTime?
  paidAmount  Decimal?  @db.Decimal(10, 2)
  couponId    String?

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  coupon Coupon? @relation(fields: [couponId], references: [id])

  @@id([userId, courseId])
}

model LessonProgress {
  id            String    @id @default(cuid())
  userId        String
  lessonId      String
  courseId      String
  completedAt   DateTime?
  watchPosition Int       @default(0)

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

// ─── Quiz ─────────────────────────────────────────────────────────────────────

model Quiz {
  id               String  @id @default(cuid())
  lessonId         String  @unique
  passingScore     Int     @default(70)
  timeLimitSecs    Int?
  randomize        Boolean @default(false)
  maxAttempts      Int?
  showAnswersAfter Boolean @default(true)

  lesson    Lesson        @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  questions Question[]
  attempts  QuizAttempt[]
}

model Question {
  id      String       @id @default(cuid())
  quizId  String
  type    QuestionType
  content String       @db.Text
  order   Int
  points  Int          @default(1)

  quiz    Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  answers Answer[]
}

model Answer {
  id         String  @id @default(cuid())
  questionId String
  content    String
  isCorrect  Boolean @default(false)

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model QuizAttempt {
  id          String    @id @default(cuid())
  quizId      String
  userId      String
  score       Int
  passed      Boolean
  startedAt   DateTime  @default(now())
  submittedAt DateTime?

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
}

// ─── Certificates & Badges ───────────────────────────────────────────────────

model Certificate {
  id         String    @id @default(cuid())
  userId     String
  courseId   String
  issuedAt   DateTime  @default(now())
  verifyCode String    @unique @default(cuid())
  pdfUrl     String?
  revokedAt  DateTime?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

model Badge {
  id          String    @id @default(cuid())
  name        String
  icon        String
  xpRequired  Int?
  description String

  userBadges UserBadge[]
}

model UserBadge {
  userId   String
  badgeId  String
  earnedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id])

  @@id([userId, badgeId])
}

model XPTransaction {
  id          String   @id @default(cuid())
  userId      String
  amount      Int
  reason      XPReason
  referenceId String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Payments ────────────────────────────────────────────────────────────────

model Payment {
  id                    String        @id @default(cuid())
  userId                String
  courseId              String?
  stripePaymentIntentId String        @unique
  amount                Decimal       @db.Decimal(10, 2)
  currency              String        @default("THB")
  status                PaymentStatus @default(PENDING)
  invoiceUrl            String?
  createdAt             DateTime      @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course? @relation(fields: [courseId], references: [id])
}

model Subscription {
  id                   String   @id @default(cuid())
  userId               String   @unique
  stripeSubscriptionId String   @unique
  plan                 String
  status               String
  currentPeriodEnd     DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Coupon {
  id            String       @id @default(cuid())
  code          String       @unique
  discountType  DiscountType
  discountValue Decimal      @db.Decimal(10, 2)
  maxUses       Int?
  usedCount     Int          @default(0)
  expiresAt     DateTime?

  enrollments Enrollment[]
}

// ─── Live Classes ─────────────────────────────────────────────────────────────

model LiveClass {
  id            String   @id @default(cuid())
  courseId      String
  instructorId  String
  title         String
  scheduledAt   DateTime
  zoomMeetingId String?
  zoomJoinUrl   String?
  recordingUrl  String?
  createdAt     DateTime @default(now())

  course     Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  instructor User   @relation("InstructorLiveClasses", fields: [instructorId], references: [id])
}

// ─── Forum ────────────────────────────────────────────────────────────────────

model ForumPost {
  id        String   @id @default(cuid())
  courseId  String
  userId    String
  parentId  String?
  content   String   @db.Text
  isPinned  Boolean  @default(false)
  isHidden  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent  ForumPost?  @relation("Replies", fields: [parentId], references: [id])
  replies ForumPost[] @relation("Replies")
}

// ─── Reviews ──────────────────────────────────────────────────────────────────

model Review {
  id        String   @id @default(cuid())
  userId    String
  courseId  String
  rating    Int
  comment   String?  @db.Text
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}
